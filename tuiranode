#!/bin/bash
# Tuiranode CLI wrapper script

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# JAR file location (use the shaded version with all dependencies)
JAR_FILE="$SCRIPT_DIR/tuituicoin/target/tuituinode-1.0-SNAPSHOT-shaded.jar"

# Check if JAR exists
if [ ! -f "$JAR_FILE" ]; then
    echo "Error: JAR file not found at $JAR_FILE"
    echo "Please run: mvn clean package"
    exit 1
fi

# Execute the JAR with all passed arguments
java -jar "$JAR_FILE" "$@"
